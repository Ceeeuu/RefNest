# Copy this file to .env and fill in real values. .env is git-ignored.
SECRET_KEY=change-me

# PostgreSQL — run the pgvector image:
#   docker run -d --name refnest-db -e POSTGRES_PASSWORD=... \
#     -e POSTGRES_DB=refnest -p 5433:5432 pgvector/pgvector:pg18
DB_NAME=refnest
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_HOST=localhost
DB_PORT=5433

# OpenAI (used from Stage 3 onward)
OPENAI_API_KEY=sk-...
